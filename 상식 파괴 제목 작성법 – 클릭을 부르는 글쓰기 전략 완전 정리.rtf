\f0\fs26 \cf0 \uc0\u49345 \u49885  \u54028 \u44340  \u51228 \u47785  \u51089 \u49457 \u48277  \'96 \u53364 \u47533 \u51012  \u48512 \u47476 \u45716  \u44544 \u50416 \u44592  \u51204 \u47029  \u50756 \u51204  \u51221 \u47532 \
\
1. \uc0\u50780  \u51228 \u47785 \u50640  '\u49345 \u49885  \u54028 \u44340 '\u47484  \u45347 \u50612 \u50556  \u54624 \u44620 ?\
\uc0\u50864 \u47532  \u45516 \u45716  \u51648 \u47336 \u54620  \u44152  \u49899 \u50612 \u54620 \u45796 . \u48376 \u51064 \u51060  \u51069 \u44592 \u50640 \u46020  \u51648 \u47336 \u54620  \u51228 \u47785 \u44284  \u45236 \u50857 \u51008  \u49345 \u45824 \u48169 \u46020  \u51069 \u51648  \u50506 \u45716 \u45796 \u45716  \u44152  \u44592 \u50613 \u54644 \u50556  \u54620 \u45796 . \u51069 \u45716  \u49324 \u46988 \u51004 \u47196  \u54616 \u50668 \u44552  \u45516 \u50640  \u52649 \u44201 \u51012  \u51460  \u49373 \u44033 \u51012  \u54644 \u50556  \u54620 \u45796 .\
\uc0\u49688 \u47566 \u51008  \u44305 \u44256 \u50752  \u50728 \u46972 \u51064 \u49345 \u51032  \u44544 \u51060  "\u45208 \u47484  \u48400  \u45804 \u46972 "\u44256  \u45212 \u47532 \u47484  \u52824 \u44256  \u51080 \u45796 . \u49324 \u46988 \u51008  \u54616 \u47336 \u50640  \u49688 \u48177  \u44060 \u51032  \u44592 \u49324 \u50752  \u48660 \u47196 \u44536  \u44544 , \u50976 \u53916 \u48652  \u46321 \u51012  \u48376 \u45796 . \u44536 \u51473 \u50640 \u49436  \u49440 \u53469 \u48155 \u45716  \u44148  \u45800  1%\u49104 \u51060 \u45796 . \u51060 \u47088  \u49345 \u54889 \u50640 \u49436  \u45817 \u49888 \u51060  \u50612 \u46500  \u44544 \u51012  \u50420 \u45796 \u44256  \u54644 \u49436  \u49324 \u46988 \u46308 \u51060  \u51069 \u50612  \u51460  \u44032 \u45733 \u49457 \u51008  \u50630 \u45796 . \u44536 \u47000 \u49436  '\u49345 \u49885  \u54028 \u44340 '\u44032  \u54596 \u50836 \u54616 \u45796 .\
\uc0\u49345 \u49885  \u54028 \u44340 \u46976 , \u49324 \u46988 \u46308 \u51060  \u51068 \u48152 \u51201 \u51004 \u47196  \u50508 \u44256  \u51080 \u45716  \u49345 \u49885 \u51012  \u46244 \u51665 \u50612 \u49436  \u45516 \u50640  \u52649 \u44201 \u51012  \u51452 \u45716  \u44544 \u51012  \u51060 \u50857 \u54644  \u53364 \u47533 \u51012  \u50976 \u46020 \u54616 \u45716  \u44592 \u48277 \u51060 \u45796 .\
\
2. \uc0\u49345 \u49885  \u54028 \u44340 \u46976  \u47924 \u50631 \u51064 \u44032 ?\
\uc0\u48516 \u49437  \u50696 \u49884 \
\
"\uc0\u51333 \u54633  1\u46321 \u54620  \u51089 \u44032 \u44032  \u47568 \u54616 \u45716  \u45817 \u49888 \u51032  \u44544 \u51060  \u44060 \u44057 \u51008  \u51060 \u50976 "\
"\uc0\u49340 \u49457  \u51060 \u51116 \u50857 \u51060  \u47568 \u54616 \u45716  \u45817 \u49888 \u51060  \u44060 \u44057 \u51060  \u44032 \u45212 \u54620  \u51060 \u50976 "\
\
\uc0\u8594  \u51060 \u47088  \u51228 \u47785 \u46308 \u51008  \u45516 \u50640  \u52649 \u44201 \u51012  \u51452 \u45716  \u44544 \u51012  \u51060 \u50857 \u54644  \u49324 \u46988 \u46308 \u51032  \u53364 \u47533 \u51012  \u50976 \u46020 \u54620 \u45796 .\
\uc0\u49345 \u49885  \u54028 \u44340 \u51032  \u54645 \u49900  \u50896 \u47532 \
\uc0\u51068 \u48152 \u51201  \u49345 \u49885 : \u48660 \u47196 \u44536 \u47484  \u50416 \u45716  \u49324 \u46988 \u46308 \u51008  \u45824 \u48512 \u48516  \u44368 \u50577 \u51060  \u51080 \u44256  \u50837 \u51012  \u50416 \u51648  \u50506 \u45716 \u45796 .\
\uc0\u49345 \u49885  \u54028 \u44340  \u51228 \u47785 : "\u48337 \u49888 \u50500  \u50780  \u51060 \u47111 \u44172  \u44544 \u51012  \u47803 \u50024 ?"\
\uc0\u8594  \u51068 \u48152 \u51201 \u51004 \u47196  \u50696 \u51032  \u48148 \u47480  \u44544  \u49549 \u50640 \u49436  \u51060 \u47088  \u54028 \u44201 \u51201 \u51064  \u51228 \u47785 \u51060  \u46321 \u51109 \u54616 \u47732 , \u45516 \u44032  \u47688 \u52628 \u44256  \u53364 \u47533 \u54616 \u44172  \u46108 \u45796 .\
\
3. \uc0\u49345 \u49885  \u54028 \u44340  \u49892 \u51204  \u50696 \u49884 \u46308 \
\uc0\u50696 \u49884  \u9312  \u45824 \u54617  \u46041 \u50500 \u47532  \u54861 \u48372 \
\uc0\u51228 \u47785 : \u49888 \u51077 \u49373 \u48516 \u46308  \u45824 \u54617  \u49373 \u54876  \u47581 \u54616 \u44256  \u49910 \u51004 \u47732  \u51208 \u45824  \u51069 \u51648  \u47560 \u49464 \u50836 .\
\uc0\u45236 \u50857 : "\u49888 \u51077 \u49373 \u48516 \u46308  \u45824 \u54617  \u49373 \u54876  \u47581 \u54616 \u44256  \u49910 \u51004 \u47732  \u51208 \u45824  \u51069 \u51648  \u47560 \u49464 \u50836 . \u44536 \u47088 \u45936 \u46020  \u46308 \u50612 \u50724 \u49512 \u45348 \u50836 ? \u47581 \u54616 \u44256  \u49910 \u51648  \u50506 \u51004 \u49888  \u44163  \u44057 \u49845 \u45768 \u45796 . \u51228 \u44032  \u45824 \u54617 \u50640  \u46308 \u50612 \u50752 \u49436  \u44032 \u51109  \u51096 \u54620  \u51068  \u51473  \u54616 \u45208 \u44032  '\u47784 \u45797 \u48520 '\u51060 \u46972 \u45716  \u46041 \u50500 \u47532 \u50640  \u46308 \u50612 \u50728  \u44163 \u51077 \u45768 \u45796 . \u45909 \u48516 \u50640  \u51109 \u54617 \u49373 \u51060  \u46112  \u49688  \u51080 \u50632 \u44256 , \u54665 \u48373 \u54620  \u45824 \u54617  \u49373 \u54876 \u46020  \u54616 \u44256 , \u52572 \u44256 \u51032  \u49440 \u54980 \u48176 \u46308 \u51012  \u47564 \u45216  \u49688  \u51080 \u50632 \u49845 \u45768 \u45796 ."\
\uc0\u8594  "\u51069 \u51648  \u47560 \u49464 \u50836 "\u46972 \u45716  \u50669 \u48156 \u49345 \u51060  \u50724 \u55176 \u47140  \u53364 \u47533 \u51012  \u50976 \u46020 \u54620 \u45796 .\
\uc0\u50696 \u49884  \u9313  \u50976 \u47749 \u51064  \u51060 \u48120 \u51648  \u46244 \u51665 \u44592  (\u48169 \u49884 \u54785 , \u48149 \u51652 \u50689 )\
\uc0\u48169 \u49884 \u54785 , \u48149 \u51652 \u50689 \u51012  \u49373 \u44033 \u54616 \u47732  \u46496 \u50724 \u47476 \u45716  \u51060 \u48120 \u51648 :\
\
\uc0\u46024 \u51060  \u47566 \u44192 \u45796 \
\uc0\u48512 \u47084 \u50868  \u49334 \u51012  \u49328 \u45796 \
\uc0\u47672 \u47532 \u44032  \u51339 \u45796 \
\uc0\u54620 \u44397  \u49324 \u54924 \u50640 \u49436  \u49457 \u44277 \u54664 \u45796 \
\
\uc0\u49345 \u49885  \u54028 \u44340  \u51201 \u50857 :\
\
"\uc0\u48169 \u49884 \u54785 , \u48149 \u51652 \u50689 \u51008  \u50616 \u47200 \u50640 \u49436  \u45432 \u52636 \u46108  \u44163  \u48372 \u45796  \u46024 \u51060  \u50630 \u45796 ." \u8596  \u46024 \u51060  \u47566 \u44192 \u45796 \
"\uc0\u48169 \u49884 \u54785 , \u48149 \u51652 \u50689 \u52376 \u47100  \u51208 \u45824  \u49332 \u51648  \u47560 \u49464 \u50836 . \u48520 \u54665 \u54624  \u49688 \u48150 \u50640  \u50630 \u49845 \u45768 \u45796 ." \u8596  \u48512 \u47084 \u50868  \u49334 \u51012  \u49328 \u45796 \
"\uc0\u48169 \u49884 \u54785 , \u48149 \u51652 \u50689 \u51032  \u51064 \u49373 \u51008  \u49324 \u49892 \u49345  \u49457 \u44277 \u54620  \u51064 \u49373 \u51060  \u50500 \u45768 \u45796 ." \u8596  \u54620 \u44397  \u49324 \u54924 \u50640 \u49436  \u49457 \u44277 \u54664 \u45796 \
\
\uc0\u8594  \u45824 \u51473 \u51060  \u44032 \u51652  \u44557 \u51221 \u51201  \u51060 \u48120 \u51648 \u47484  \u51221 \u48152 \u45824 \u47196  \u46244 \u51665 \u51004 \u47732 , \u49324 \u46988 \u46308 \u51008  "\u50780 ?"\u46972 \u45716  \u44417 \u44552 \u51613 \u50640  \u53364 \u47533 \u54620 \u45796 .\
\uc0\u50696 \u49884  \u9314  \u49436 \u50872 \u45824 , \u54616 \u48260 \u46300  \u51060 \u48120 \u51648  \u46244 \u51665 \u44592 \
\uc0\u49436 \u50872 \u45824 , \u54616 \u48260 \u46300  \u50672 \u49345  \u51060 \u48120 \u51648 :\
\
\uc0\u54617 \u44396 \u51201 \u51060 \u45796 \
\uc0\u50648 \u47532 \u53944 \u45796 \
\uc0\u48512 \u47784 \u45784 \u51060  \u46024 \u51060  \u47566 \u51012  \u44163  \u44057 \u45796 \
\uc0\u51652 \u51676  \u51648 \u45733 \u51060  \u45458 \u45796 \
\uc0\u47952 \u46304 \u51648  \u51096  \u54644 \u45244  \u44163  \u44057 \u45796 \
\
\uc0\u48152 \u45824 \u46104 \u45716  \u51060 \u48120 \u51648  \u54876 \u50857 : "\u49828 \u53440 \u53944 \u50629 \u50640  \u46308 \u50612 \u44032 \u51648  \u47560 \u46972 " \'96 \u49436 \u50872 \u45824 , \u54616 \u48260 \u46300 \u50752  \u49436 \u50872  \u52636 \u49888  \u45824 \u54364  \u51080 \u45716  \u44275  \u44032 \u51648  \u47560 \u46972  \u44057 \u51008  \u51228 \u47785 \u51004 \u47196  \u50648 \u47532 \u53944  \u51060 \u48120 \u51648 \u47484  \u46244 \u51665 \u45716 \u45796 .\
\uc0\u50696 \u49884  \u9315  \u51228 \u54408  \u54032 \u47588  \u44544  (\u47792 \u51077 \u51032  \u48169 )\
\uc0\u51228 \u54408  \u54032 \u47588  \u44544 : \u47792 \u51077 \u51032  \u48169 , \u50732 \u54644  \u44396 \u47588 \u54620  \u52572 \u44256 \u51032  \u51228 \u54408 \
\uc0\u51068 \u48152 \u51201  \u49345 \u49885 : \u49828 \u47560 \u53944 \u54256  \u51473 \u46021 \u50640 \u49436  \u48279 \u50612 \u45208 \u50556  \u54620 \u45796 .\
\uc0\u49345 \u49885  \u54028 \u44340  \u51228 \u47785 \u46308 :\
\
"\uc0\u49828 \u47560 \u53944 \u54256  \u51473 \u46021 \u51060  \u50724 \u55176 \u47140  \u51648 \u45733 \u51012  \u45458 \u51060 \u45716  \u51060 \u50976 "\
"\uc0\u49828 \u47560 \u53944 \u54256  \u51473 \u46021 \u51060  \u50500 \u51060 \u51032  \u47672 \u47532 \u47484  \u47569 \u44172  \u47564 \u46300 \u45716  \u51060 \u50976 "\
"\uc0\u50528 \u54540 \u51032  \u53468 \u48660 \u47551  \u48512 \u49436  \u45824 \u54364 \u44032  \u51088 \u49888 \u51032  \u50500 \u51060 \u50640 \u44172  \u51208 \u45824  \u53468 \u48660 \u47551 \u51012  \u51536 \u50668 \u51452 \u51648  \u50506 \u45716  \u51060 \u50976 "\
\
\uc0\u8594  \u47784 \u46160 \u44032  "\u49828 \u47560 \u53944 \u54256  \u51473 \u46021 \u51008  \u45208 \u49240 \u45796 "\u44256  \u49373 \u44033 \u54616 \u45716  \u49345 \u49885 \u51012  \u46244 \u51665 \u50612 \u49436  \u54840 \u44592 \u49900 \u51012  \u51088 \u44537 \u54620 \u45796 .\
\
4. \uc0\u46024 , \u47749 \u50696 , \u50837 \u47581 \u50640  \u45824 \u54644  \u49556 \u51649 \u54644 \u51256 \u46972 \
\uc0\u45236 \u44032  \u44032 \u51109  \u44221 \u44228 \u54616 \u45716  \u48512 \u47448 \u44032  \u51080 \u45796 . \u51088 \u49888 \u51032  \u50837 \u47581 \u51012  \u44048 \u52628 \u44256  \u44536 \u47092 \u46319 \u54616 \u44172  \u54252 \u51109 \u54616 \u45716  \u51064 \u44036 \u46308 \u51060 \u45796 .\
\
"\uc0\u51200 \u45716  \u49440 \u54620  \u50689 \u54693 \u47141 \u51012  \u45180 \u52824 \u44256  \u49910 \u50612 \u50836 "\
"\uc0\u51200 \u45716  \u49324 \u50629 \u51004 \u47196  \u49464 \u49345 \u51012  \u51060 \u47213 \u44172  \u54616 \u44256  \u49910 \u50612 \u50836 "\
\
\uc0\u51088 \u49888 \u51032  \u49324 \u50837 \u50640  \u45824 \u54644  \u47568 \u54616 \u51648  \u50506 \u44256 , \u51060 \u47088  \u47568 \u47564  \u54616 \u45716  \u49324 \u46988 \u51012  \u51452 \u51032 \u54644 \u46972 .\
\uc0\u54645 \u49900  \u47700 \u49884 \u51648 : \u44536 \u45285  \u46024 \u51060  \u51339 \u44256  \u47749 \u50696 \u44032  \u51339 \u44256  \u49465 \u49828 \u44032  \u51339 \u45796 \u44256  \u49556 \u51649 \u55176  \u47568 \u54644 \u46972 . \u48512 \u45124 \u47084 \u50872  \u44163  \u50630 \u45796 . \u51064 \u44036 \u51008  \u44536 \u45285  \u44536 \u47088  \u51316 \u51116 \u45796 . \u51060 \u47088  \u49556 \u51649 \u54632 \u51060  \u44544 \u50640 \u46020  \u46300 \u47084 \u45208 \u50556  \u49324 \u46988 \u46308 \u51060  \u51652 \u51221 \u49457 \u51012  \u45712 \u45184 \u45796 .\
\
5. \uc0\u52628 \u49345 \u50612  \u53448 \u52636  3\u50896 \u52825  \'96 \u51228 \u47785 \u51012  \u44396 \u52404 \u51201 \u51004 \u47196  \u47564 \u46300 \u45716  \u48277 \
\uc0\u52628 \u49345 \u51201 \u51064  \u51228 \u47785 \u51008  \u50500 \u47924 \u46020  \u53364 \u47533 \u54616 \u51648  \u50506 \u45716 \u45796 . \u44396 \u52404 \u51201 \u51004 \u47196  \u48148 \u44984 \u45716  3\u44032 \u51648  \u50896 \u52825 \u51060  \u51080 \u45796 .\
\uc0\u50896 \u52825  \u9312  \u44396 \u52404 \u51201 \u51064  \u51452 \u50612 \
\uc0\u52628 \u49345 \u50612 : "\u49436 \u50872 \u50640 \u49436  \u44032 \u51109  \u49888 \u45208 \u45716  \u51109 \u49548 "\
\uc0\u44256 \u52828  \u51228 \u47785 :\
\
"\uc0\u50640 \u48260 \u47004 \u46300  \u49324 \u51109 \u46020  \u52286 \u45716  \u49436 \u50872 \u50640 \u49436  \u44032 \u51109  \u49888 \u45208 \u45716  \u51109 \u49548 "\
"\uc0\u51648 \u46300 \u47000 \u44260 \u46020  \u52286 \u45716  \u49436 \u50872 \u50640 \u49436  \u44032 \u51109  \u49888 \u45208 \u45716  \u51109 \u49548 "\
\
\uc0\u8594  \u44396 \u52404 \u51201 \u51064  \u51064 \u47932 (\u51452 \u50612 )\u51012  \u45347 \u51004 \u47732  \u49888 \u47280 \u50752  \u54840 \u44592 \u49900 \u51060  \u46041 \u49884 \u50640  \u49373 \u44596 \u45796 .\
\uc0\u50896 \u52825  \u9313  \u49707 \u51088 \u51032  \u50896 \u52825 \
\uc0\u52628 \u49345 \u50612 : "\u50976 \u53916 \u48652  \u51096 \u54616 \u45716  \u48277 "\
\uc0\u44256 \u52828  \u51228 \u47785 : "\u54620  \u45804  \u47564 \u50640  \u44396 \u46021 \u51088  10\u47564  \u47749  \u47564 \u46304  \u50976 \u53916 \u48260 \u44032  \u47568 \u54616 \u45716  '\u44396 \u46021 \u51088  \u45720 \u47532 \u44592 '"\
\uc0\u52628 \u49345 \u50612 : "\u51339 \u51008  \u51228 \u54408 \u51077 \u45768 \u45796 ."\
\uc0\u44256 \u52828  \u51228 \u47785 : "\u51076 \u49345  \u49884 \u54744 \u50640 \u49436  \u44221 \u51137 \u49324  10\u44275  \u49892 \u54744  \u51473 \u50640  1\u46321 \u51012  5\u48264 , 2\u46321  1\u48264  \u52264 \u51648 \u54620  \u51228 \u54408 "\
\uc0\u8594  \u49707 \u51088 \u44032  \u46308 \u50612 \u44032 \u47732  \u44396 \u52404 \u49457 \u44284  \u49888 \u47280 \u44032  \u50732 \u46972 \u44036 \u45796 .\
\uc0\u50896 \u52825  \u9314  \u44036 \u51217 \u51613 \u47749 \
\uc0\u52628 \u49345 \u50612 : "\u45236 \u44032  \u52628 \u52380 \u54616 \u45716  \u50668 \u54665 \u51648  3\u44275 "\
\uc0\u44256 \u52828  \u51228 \u47785 :\
\
"72\uc0\u44060 \u44397  \u46028 \u50500 \u45796 \u45772  \u45236 \u44032  \u52628 \u52380 \u54616 \u45716  \u50668 \u54665 \u51648  3\u44275 "\
"\uc0\u54693 \u49688  \u47588 \u51109  4\u45380  \u52264  \u51649 \u50896 \u51060  \u52628 \u52380 \u54616 \u45716  \u54693 \u49688  \u45796 \u49455  \u44032 \u51648 "\
"\uc0\u54693 \u49688  \u47588 \u51109  4\u45380  \u52264  \u51649 \u50896 \u51060 , \u44600 \u44032 \u45716  \u45224 \u51088 \u50640 \u44172  '\u54693 \u49688 \u44032  \u47952 \u50696 \u50836 ?'\u46972 \u44256  \u47932 \u50612 \u48400 \u49436  \u45813 \u51012  \u46308 \u51008  4\u44032 \u51648 "\
\
\uc0\u8594  \u44221 \u54744 \u51060 \u45208  \u51204 \u47928 \u49457 \u51012  \u44036 \u51217 \u51201 \u51004 \u47196  \u51613 \u47749 \u54616 \u47732  \u53364 \u47533 \u47456 \u51060  \u50732 \u46972 \u44036 \u45796 .\
\uc0\u49707 \u51088 \u51032  \u50896 \u52825  + \u44036 \u51217 \u51613 \u47749  \u51312 \u54633 \
\uc0\u52628 \u49345 \u50612 : "\u47792 \u51077 \u51032  \u48169 , \u50732 \u54644  \u44396 \u47588 \u54620  \u52572 \u44256 \u51032  \u50500 \u51060 \u53596 "\
\uc0\u44256 \u52828  \u51228 \u47785 : "2023\u45380  10\u50613 \u51012  \u49548 \u48708 \u54616 \u47732 \u49436  \u44032 \u51109  \u51339 \u50520 \u45912  \u50500 \u51060 \u53596 "\
\uc0\u8594  \u49707 \u51088 (10\u50613 )\u50752  \u44036 \u51217 \u51613 \u47749 (\u44536 \u47564 \u53372  \u49548 \u48708 \u54620  \u49324 \u46988 )\u51060  \u44208 \u54633 \u46104 \u47732  \u53364 \u47533 \u47141 \u51060  \u44537 \u45824 \u54868 \u46108 \u45796 .\
\
6. \uc0\u52628 \u49345 \u50612  \u8594  \u44396 \u52404 \u51201  \u51228 \u47785  \u48320 \u54872  \u52628 \u44032  \u50696 \u49884 \
\uc0\u52628 \u49345 \u50612 \u44256 \u52828  \u51228 \u47785 \u45236 \u44032  \u44036  \u52572 \u44256 \u51032  \u50668 \u54665 \u51648 \u45236 \u44032  78\u44060 \u44397  \u50668 \u54665 \u54616 \u47732 \u49436  \u44032 \u51109  \u51339 \u50520 \u45912  1\u46321  \u50668 \u54665 \u51648 \u48512 \u51088  \u46104 \u45716  \u48277 \u50900  1000\u47564 \u50896  \u48260 \u45716  \u48277 \u48512 \u51088  \u46104 \u45716  \u48277 \u54924 \u49324 \u50896 \u51060  \u48512 \u50629 \u51004 \u47196  \u50900  1,000\u47564  \u50896  \u48260 \u45716  \u48277 \u48512 \u51088  \u46104 \u45716  \u48277 20\u49332  \u54924 \u49324 \u50896 \u51064  \u45236 \u44032  \u48512 \u50629 \u51004 \u47196  \u50900  1,000\u47564  \u50896  3\u44060 \u50900  \u47564 \u50640  \u48268 \u50612 \u46308 \u51064  \u48169 \u48277 \u44277 \u48512 \u47484  \u51096 \u54616 \u45716  \u48277 \u54616 \u47336  3\u49884 \u44036 \u50473  \u44277 \u48512 \u54616 \u44256  \u49436 \u50872 \u45824  \u44032 \u45716  \u48277 \
\uc0\u8594  \u51452 \u50612 \u44032  \u44396 \u52404 \u51201 \u51060 \u44256 , \u49707 \u51088 \u44032  \u46308 \u50612 \u44032 \u44256 , \u44036 \u51217 \u51613 \u47749 \u51060  \u51080 \u51012 \u49688 \u47197  \u51228 \u47785 \u51032  \u53364 \u47533 \u47456 \u51008  \u50732 \u46972 \u44036 \u45796 .\
\
7. \uc0\u52628 \u49345 \u50612  \u53448 \u52636  \u50896 \u52825  \u51312 \u54633  \'96 3\u44032 \u51648 \u47484  \u49438 \u51004 \u47732  \u52572 \u44053 \u51060  \u46108 \u45796 \
\uc0\u54616 \u45208 \u51032  \u50896 \u52825 \u47564  \u50416 \u45716  \u44163 \u48372 \u45796  \u50668 \u47084  \u50896 \u52825 \u51012  \u51312 \u54633 \u54616 \u47732  \u51228 \u47785 \u51032  \u54028 \u44340 \u47141 \u51060  \u44537 \u45824 \u54868 \u46108 \u45796 .\
\uc0\u49707 \u51088 \u51032  \u50896 \u52825  + \u44036 \u51217 \u51613 \u47749  + \u44396 \u52404 \u51201 \u51064  \u51452 \u50612 \
