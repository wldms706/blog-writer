\uc0\u51228 \u47785 : "\u44032 \u45212 \u54620  \u49324 \u46988 \u51032  \u45516 , \u52649 \u44201 \u51201 \u51064  \u48512 \u51088 \u51032  \u45516 "\
\uc0\u8594  \u51228 \u47785 \u51012  \u48376  \u49324 \u46988 \u46308 \u51032  \u49900 \u47532 : "\u50500  \u45208 \u51032  \u45516 \u44032  \u51200 \u47088  \u54805 \u53468 \u47732  \u45236 \u44032  \u44032 \u45212 \u54644 \u51648 \u51648  \u50506 \u51012 \u44620 ..?"\
