8. \uc0\u49552 \u49892  \u54924 \u54588  \u54200 \u54693  \'96 \u51064 \u44036 \u51032  \u48376 \u45733 \u51012  \u51088 \u44537 \u54616 \u45716  \u51228 \u47785  \u44592 \u48277 \
\uc0\u50896 \u47532 \
\uc0\u48192 \u51012  \u52376 \u51020  \u48372 \u45716  \u46041 \u47932 \u44284  \u51064 \u44036 \u51008  \u44277 \u54252 \u49900 \u51012  \u44054 \u45716 \u45796 . \u50556 \u49373 \u50640 \u49436  \u47564 \u45212  \u49324 \u51088 \u45716  \u50864 \u47532 \u50640 \u44172  \u48376 \u45733 \u51201  \u44277 \u54252 \u44048 \u51012  \u51456 \u45796 . \u45229 \u46496 \u47084 \u51648 \u47484  \u45800  \u54620  \u48264 \u46020  \u48376  \u51201  \u50630 \u45716  1\u49332  \u50612 \u47536 \u50500 \u51060 \u45716  \u45576 \u50526 \u50640  \u45229 \u46496 \u47084 \u51648 \u44032  \u51080 \u51004 \u47732  \u48376 \u45733 \u51201 \u51004 \u47196  \u44277 \u54252 \u44048 \u51012  \u45712 \u45180 \u44256  \u54588 \u54620 \u45796 . \u47784 \u46304  \u46041 \u47932 \u51008  \u49373 \u51316 \u51012  \u48520 \u47532 \u54616 \u44172  \u47564 \u46300 \u45716  \u44163 \u50640  '\u51452 \u51032  \u51665 \u51473 '\u54616 \u47140 \u45716  \u48376 \u45733 \u51060  \u51080 \u45796 .\
\uc0\u51060 \u52376 \u47100  \u51064 \u44036 \u51032  \u45516 \u45716  \u49373 \u51316 \u44284  \u48264 \u49885 \u50640  \u52572 \u51201 \u54868 \u46104 \u50612  \u51080 \u45796 . \u51088 \u49888 \u51032  \u49373 \u51316 \u51012  \u48520 \u47532 \u54616 \u44172  \u47564 \u46300 \u45716  \u51221 \u48372 \u50640  \u45824 \u54644  '\u44480 \u44032  \u51921 \u44555 '\u54616 \u44172 \u45140  \u51652 \u54868 \u46104 \u50632 \u45796 \u45716  \u47568 \u51060 \u45796 . \u44148 \u44053 , \u46024 , \u49373 \u44228 , \u51064 \u49373 , \u54217 \u54032  \u46321 \u51060  \u48520 \u47532 \u54644 \u51656  \u48277 \u54620  \u44544  \u51228 \u47785 \u51008  \u49324 \u46988 \u46308 \u51032  \u51060 \u47785 \u51012  \u45132  \u49688 \u48150 \u50640  \u50630 \u45796 .\
\uc0\u49552 \u49892  \u54924 \u54588  \u54200 \u54693  \u51228 \u47785  \u50696 \u49884 \
\
