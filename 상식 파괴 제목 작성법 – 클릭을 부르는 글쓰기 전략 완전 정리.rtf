\uc0\u44256 \u52828  \u51228 \u47785 : "2023\u45380  \u48288 \u49828 \u53944 \u49472 \u47084  1\u46321  \u51089 \u44032 \u51032  \u47792 \u51077 \u46020 \u47484  \u44537 \u46020 \u47196  \u45458 \u50668 \u51452 \u45716  \u50500 \u51060 \u53596 "\
\uc0\u8594  \u49707 \u51088 (2023\u45380  \u48288 \u49828 \u53944 \u49472 \u47084  1\u46321 ) + \u44036 \u51217 \u51613 \u47749 (\u48288 \u49828 \u53944 \u49472 \u47084  \u51089 \u44032 ) + \u44396 \u52404 \u51201  \u51452 \u50612 \u44032  \u47784 \u46160  \u46308 \u50612 \u44032 \u47732  \u53364 \u47533 \u47456 \u51060  \u54253 \u48156 \u54620 \u45796 .\
\uc0\u49707 \u51088 \u51032  \u50896 \u52825  + \u44396 \u52404 \u51201 \u51064  \u51452 \u50612 \
\uc0\u52628 \u49345 \u50612 : "\u47792 \u51077 \u51032  \u48169 , \u50732 \u54644  \u44396 \u47588 \u54620  \u52572 \u44256 \u51032  \u50500 \u51060 \u53596 "\
\uc0\u44256 \u52828  \u51228 \u47785 : "\u54616 \u47336  \u47540 \u49828  3\u49884 \u44036 \u50473  \u48372 \u45796 \u44032 , \u54616 \u47336  \u47540 \u49828  0\u48516 \u51012  \u48372 \u44172  \u54644 \u51456  \u50500 \u51060 \u53596 "\
\uc0\u8594  \u44396 \u52404 \u51201  \u49707 \u51088 (3\u49884 \u44036  \u8594  0\u48516 )\u50752  \u45572 \u44396 \u45208  \u44277 \u44048 \u54624  \u49688  \u51080 \u45716  \u51452 \u50612 (\u47540 \u49828  \u51473 \u46021 )\u44032  \u44208 \u54633 \u46104 \u47732  \u44053 \u47141 \u54620  \u51228 \u47785 \u51060  \u46108 \u45796 .\
